    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import express from \"express\";\nimport path from \"path\";\nimport cors from \"cors\";\nimport { createServer as createViteServer } from \"vite\";\nimport { GoogleGenAI } from \"@google/genai\";\n\nasync function startServer() {\n  const app = express();\n  const PORT = 3000;\n\n  app.use(cors());\n  app.use(express.json());\n\n  const ai = new GoogleGenAI({ apiKey: process.env.GEMINI_API_KEY });\n\n  // API Routes\n  app.post(\"/api/auth/login\", (req, res) => {\n    res.json({ token: \"mock-jwt-token\", user: { id: \"1\", name: \"Alex Student\", email: req.body.email } });\n  });\n\n  app.post(\"/api/auth/register\", (req, res) => {\n    res.json({ token: \"mock-jwt-token\", user: { id: \"1\", name: req.body.name, email: req.body.email } });\n  });\n\n  app.post(\"/api/assistant/chat\", async (req, res) => {\n    try {\n      const { messages } = req.body;\n      const responseStream = await ai.models.generateContentStream({\n        model: \"gemini-2.5-flash\",\n        contents: messages,\n        systemInstruction: \"You are AlumniIQ, an AI-powered Career Intelligence assistant. You help students discover alumni career paths, industry trends, and opportunities. Be professional, concise, and format data using markdown.\",\n      });\n\n      res.setHeader(\"Content-Type\", \"text/event-stream\");\n      res.setHeader(\"Cache-Control\", \"no-cache\");\n      res.setHeader(\"Connection\", \"keep-alive\");\n\n      for await (const chunk of responseStream) {\n        if (chunk.text) {\n          res.write(`data: ${JSON.stringify({ text: chunk.text })}\\n\\n`);\n        }\n      }\n      res.write(\"data: [DONE]\\n\\n\");\n      res.end();\n    } catch (error) {\n      console.error(error);\n      res.status(500).json({ error: \"Failed to generate content\" });\n    }\n  });\n\n  // Mock Alumni Data\n  const mockAlumni = [\n    { id: \"1\", name: \"Sarah Chen\", position: \"Senior Machine Learning Engineer\", company: \"Google\", country: \"United States\", industry: \"Technology\", education: \"Stanford University\", skills: [\"Python\", \"TensorFlow\", \"PyTorch\"], image: \"https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=200\" },\n    { id: \"2\", name: \"David Mueller\", position: \"Product Manager\", company: \"Stripe\", country: \"Germany\", industry: \"Fintech\", education: \"Technical University of Munich\", skills: [\"Product Strategy\", \"Agile\", \"Data Analysis\"], image: \"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=200\" },\n    { id: \"3\", name: \"Elena Rodriguez\", position: \"VP of Engineering\", company: \"Linear\", country: \"Spain\", industry: \"SaaS\", education: \"MIT\", skills: [\"System Design\", \"Leadership\", \"React\"], image: \"https://images.unsplash.com/photo-1580489944761-15a19d654956?auto=format&fit=crop&q=80&w=200\" },\n    { id: \"4\", name: \"James Wu\", position: \"Data Scientist\", company: \"OpenAI\", country: \"United States\", industry: \"Artificial Intelligence\", education: \"UC Berkeley\", skills: [\"NLP\", \"Deep Learning\", \"SQL\"], image: \"https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?auto=format&fit=crop&q=80&w=200\" },\n  ];\n\n  app.get(\"/api/alumni\", (req, res) => {\n    res.json(mockAlumni);\n  });\n\n  app.get(\"/api/analytics\", (req, res) => {\n    res.json({\n      topSkills: [{ name: \"Python\", value: 85 }, { name: \"React\", value: 72 }, { name: \"Data Analysis\", value: 68 }, { name: \"Product Management\", value: 60 }],\n      topIndustries: [{ name: \"Technology\", value: 45 }, { name: \"Finance\", value: 25 }, { name: \"Healthcare\", value: 15 }, { name: \"Education\", value: 10 }],\n      topCompanies: [{ name: \"Google\", value: 120 }, { name: \"Microsoft\", value: 95 }, { name: \"Amazon\", value: 80 }, { name: \"McKinsey\", value: 50 }],\n      careerGrowth: [{ year: \"2020\", count: 100 }, { year: \"2021\", count: 150 }, { year: \"2022\", count: 220 }, { year: \"2023\", count: 310 }, { year: \"2024\", count: 450 }]\n    });\n  });\n\n  // Vite middleware for development\n  if (process.env.NODE_ENV !== \"production\") {\n    const vite = await createViteServer({\n      server: { middlewareMode: true },\n      appType: \"spa\",\n    });\n    app.use(vite.middlewares);\n  } else {\n    const distPath = path.join(process.cwd(), \'dist\');\n    app.use(express.static(distPath));\n    app.get(\'*\', (req, res) => {\n      res.sendFile(path.join(distPath, \'index.html\'));\n    });\n  }\n\n  app.listen(PORT, \"0.0.0.0\", () => {\n    console.log(`Server running on http://localhost:${PORT}`);\n  });\n}\n\nstartServer();\n"
    }
